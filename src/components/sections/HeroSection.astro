---
import AnimatedSection from "../react/AnimatedSection.tsx";
import GradientButton from "../react/GradientButton.tsx";

interface Props {
  data: {
    headline: string;
    description: string;
    ctaText: string;
    rating: string;
    ratingText: string;
    tags: string[];
    productImage: string;
  };
}

const { data } = Astro.props;

// Split headline for gradient effect
const words = data.headline.split(" ");
const mid = Math.ceil(words.length / 2);
---

<section id="hero" class="relative bg-[#e8e8e8] overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 pt-24 md:pt-32 lg:pt-36 pb-20 md:pb-28">
<div class="flex flex-col lg:flex-row lg:items-center lg:gap-12">
      <!-- Text content -->
      <div class="flex-1 relative z-10">
        <AnimatedSection client:load>
          <h1 class="font-display font-semibold text-[56px] lg:text-[80px] leading-[0.9em] tracking-[-0.04em] gradient-text bg-gradient-to-b from-black via-[#010101] to-[#939292]" style="--tw-gradient-via-position: 60%;">
            {data.headline}
          </h1>
        </AnimatedSection>

        <AnimatedSection client:load delay={0.2}>
          <p class="mt-6 text-lg md:text-xl lg:text-2xl text-[#2a2323] tracking-tight leading-relaxed max-w-[660px]" set:html={data.description.replace(/\*\*(.*?)\*\*/g, '<strong class="font-bold">$1</strong>')} />
        </AnimatedSection>

        <AnimatedSection client:load delay={0.4}>
          <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-6">
            <GradientButton client:load className="text-2xl px-8 py-5" onClick={() => window.dispatchEvent(new Event('open-pricing-modal'))}>
              {data.ctaText}
            </GradientButton>

            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-sm text-gray-600">{data.ratingText}</span>
            </div>
          </div>
        </AnimatedSection>
      </div>

      <!-- Product image -->
      <AnimatedSection client:load delay={0.3} className="flex-1 lg:flex-[1.3] mt-12 lg:mt-0">
        <div class="relative">
          <div class="bg-[#f1f1f1] rounded-[32px] lg:rounded-[48px] overflow-hidden p-4 lg:p-6 shadow-[inset_0px_-20px_84px_0px_rgba(0,0,0,0.1)]">
            <img
              src={data.productImage}
              alt="Eagle Glass product"
              class="w-full h-auto object-contain"
            />
          </div>
        </div>
      </AnimatedSection>
    </div>

    <!-- Tags -->
    <AnimatedSection client:load delay={0.5}>
      <div class="flex flex-wrap gap-4 md:gap-8 mt-12 lg:mt-16">
        {data.tags.map((tag: string) => (
          <span class="text-sm md:text-base text-gray-800 tracking-tight">{tag}</span>
        ))}
      </div>
    </AnimatedSection>
  </div>
</section>
