---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";
import GradientButton from "../react/GradientButton.tsx";
import CarouselSlider from "../react/CarouselSlider.tsx";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    ctaText: string;
    slides: { title: string; stat?: string; backgroundColor: string; textColor: string }[];
  };
}

const { data } = Astro.props;
---

<section class="relative overflow-hidden" style="background-image: linear-gradient(180deg, rgb(232,232,232) 0%, rgb(255,255,255) 100%);">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <div class="flex flex-col lg:flex-row lg:items-center lg:gap-20">
      <!-- Left: Text + CTA -->
      <div class="flex-1 min-w-0 mb-12 lg:mb-0">
        <AnimatedSection client:visible>
          <SectionLabel text={data.label} />
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.1}>
          <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[67px] leading-[0.9em] tracking-[-0.04em] gradient-text" style="background-image: linear-gradient(-63deg, rgb(44,44,44) 69%, rgb(153,153,153) 102%);">
            {data.heading}
          </h2>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.2}>
          <p class="mt-6 text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter font-medium text-black max-w-[540px]">
            {data.description}
          </p>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.3}>
          <div class="mt-10">
            <GradientButton client:load onClick={() => window.dispatchEvent(new Event('open-pricing-modal'))}>
              {data.ctaText}
            </GradientButton>
          </div>
        </AnimatedSection>
      </div>

      <!-- Right: Cards -->
      <div class="flex-1 min-w-0">
        <CarouselSlider client:visible slides={data.slides} />
      </div>
    </div>
  </div>
</section>
