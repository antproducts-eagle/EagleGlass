---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    image: string;
  };
}

const { data } = Astro.props;
---

<section class="relative overflow-hidden" style="background-color: #fff;">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <!-- Header -->
    <div class="max-w-[800px] mb-12 lg:mb-16">
      <AnimatedSection client:visible>
        <SectionLabel text={data.label} />
      </AnimatedSection>

      <AnimatedSection client:visible delay={0.1}>
        <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[67px] leading-[0.9em] tracking-[-0.04em] gradient-text" style="background-image: linear-gradient(-45deg, rgb(0,0,0) 69%, rgb(153,153,153) 102%);">
          {data.heading}
        </h2>
      </AnimatedSection>

      <AnimatedSection client:visible delay={0.2}>
        <p class="mt-6 text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter font-medium text-black">
          {data.description}
        </p>
      </AnimatedSection>
    </div>

    <!-- Full-width image -->
    <AnimatedSection client:visible delay={0.3}>
      <div class="rounded-[24px] lg:rounded-[40px] overflow-hidden">
        <img
          src={data.image}
          alt={data.heading}
          class="w-full h-auto"
        />
      </div>
    </AnimatedSection>
  </div>
</section>
