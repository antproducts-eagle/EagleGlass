---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    cards: { title: string; description: string; image: string }[];
  };
}

const { data } = Astro.props;
---

<section class="relative overflow-x-hidden" style="background-color: #fff;">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <!-- Header -->
    <div class="max-w-[800px] mb-12 lg:mb-16">
      <AnimatedSection client:visible>
        <SectionLabel text={data.label} />
      </AnimatedSection>

      <AnimatedSection client:visible delay={0.1}>
        <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[67px] leading-[1em] tracking-[-0.04em] gradient-text" style="background-image: linear-gradient(-45deg, rgb(0,0,0) 69%, rgb(153,153,153) 102%);">
          {data.heading}
        </h2>
      </AnimatedSection>

      <AnimatedSection client:visible delay={0.2}>
        <p class="mt-6 text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter font-medium text-black">
          {data.description}
        </p>
      </AnimatedSection>
    </div>

    <!-- Cards row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {data.cards.map((card, i) => (
        <AnimatedSection client:visible delay={0.2 + i * 0.1}>
          <div class="group relative rounded-[20px] lg:rounded-[24px] overflow-hidden border border-[#e5e5e5] bg-[#f7f7f7] transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-[#d0d0d0]">
            <div class="aspect-square overflow-hidden bg-white flex items-center justify-center p-6 lg:p-8">
              <img
                src={card.image}
                alt={card.title}
                class="max-w-full max-h-full object-contain transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-4 lg:p-5 border-t border-[#e5e5e5]">
              <h3 class="font-display font-semibold text-base md:text-lg lg:text-xl leading-[1.1] tracking-tight text-black">
                {card.title}
              </h3>
              <p class="mt-1.5 text-sm lg:text-base leading-[1.3] tracking-tight text-black/50 font-medium">
                {card.description}
              </p>
            </div>
          </div>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
