---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";
import GlassLayerTooltips from "../react/GlassLayerTooltips.tsx";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    layers: { id: string; name: string; description: string; position: { top: string; left: string } }[];
    specs: { value: string; unit?: string; label: string }[];
    bulletPoints: string[];
    layersImage: string;
  };
}

const { data } = Astro.props;
---

<section class="relative overflow-hidden" style="background-image: linear-gradient(180deg, rgb(232,232,232) 0%, rgb(255,255,255) 100%);">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <div class="flex flex-col lg:flex-row lg:gap-20">
      <!-- Image with tooltips -->
      <div class="flex-1 mb-12 lg:mb-0">
        <GlassLayerTooltips
          client:visible
          layers={data.layers}
          image={data.layersImage}
        />
      </div>

      <!-- Text content -->
      <div class="flex-1">
        <AnimatedSection client:visible>
          <SectionLabel text={data.label} />
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.1}>
          <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[76px] leading-[0.9em] tracking-[-0.04em] gradient-text" style="background-image: linear-gradient(-69deg, rgb(0,0,0) 69%, rgb(153,153,153) 102%);">
            {data.heading}
          </h2>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.2}>
          <p class="mt-8 font-display font-medium text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter text-black">
            {data.description}
          </p>
        </AnimatedSection>

        <!-- Bullet points -->
        <AnimatedSection client:visible delay={0.3}>
          <ul class="mt-8 space-y-3">
            {data.bulletPoints.map((point: string) => (
              <li class="flex items-start gap-3 text-lg md:text-xl lg:text-[32px] font-display font-medium tracking-tighter">
                <span class="mt-2 w-2 h-2 rounded-full bg-black flex-shrink-0"></span>
                {point}
              </li>
            ))}
          </ul>
        </AnimatedSection>
      </div>
    </div>

    <!-- Specs row -->
    <AnimatedSection client:visible delay={0.3}>
      <div class="mt-16 lg:mt-24 grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 bg-white rounded-[24px] p-8 lg:p-12 border border-gray-100">
        {data.specs.map((spec) => (
          <div class="text-center">
            <div class="font-display font-bold text-4xl md:text-5xl lg:text-6xl tracking-tight">
              {spec.value}
              {spec.unit && <span class="text-xl md:text-2xl text-gray-400 ml-1">{spec.unit}</span>}
            </div>
            <p class="mt-2 text-sm md:text-base text-gray-500">{spec.label}</p>
          </div>
        ))}
      </div>
    </AnimatedSection>
  </div>
</section>
