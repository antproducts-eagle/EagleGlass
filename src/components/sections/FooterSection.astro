---
interface Props {
  data: {
    links: { label: string; href: string }[];
    copyright: string;
    legal: { label: string; href: string }[];
  };
}

const { data } = Astro.props;
---

<footer class="bg-[#eaeaea]">
  <div class="max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16 py-16 md:py-20">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <!-- Logo -->
      <img src="/images/logo.png" alt="Eagle Glass" class="h-8 w-auto" />

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-6 md:gap-8">
        {data.links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-semibold text-black hover:text-gray-600 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Social icons -->
      <div class="flex gap-3">
        {["facebook", "instagram", "x", "linkedin", "youtube"].map((social) => (
          <a href="#" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-200 transition-colors text-gray-600 hover:text-gray-900" aria-label={social}>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div class="my-10 border-t border-gray-300"></div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4 text-sm text-gray-600">
      <span>{data.copyright}</span>
      <div class="flex gap-6">
        {data.legal.map((link) => (
          <a href={link.href} class="underline hover:text-gray-900 transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
