---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";
import GradientButton from "../react/GradientButton.tsx";
import CtaProductCanvas from "../react/CtaProductCanvas.tsx";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    ctaText: string;
    image: string;
  };
}

const { data } = Astro.props;
---

<section class="relative bg-white overflow-x-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between">
      <!-- Left - text -->
      <div class="flex-1 max-w-[620px]">
        <AnimatedSection client:visible>
          <SectionLabel text={data.label} />
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.1}>
          <h2 class="mt-3 pb-2 font-display font-semibold text-[56px] lg:text-[80px] leading-[1em] tracking-[-0.04em] gradient-text" style="background-image: linear-gradient(-74deg, rgb(0,0,0) 69%, rgb(153,153,153) 102%);">
            {data.heading}
          </h2>
        </AnimatedSection>
      </div>

      <!-- Right - description + CTA -->
      <div class="mt-8 lg:mt-auto lg:max-w-[565px]">
        <AnimatedSection client:visible delay={0.2}>
          <p class="font-display font-medium text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter text-[#080808]">
            {data.description}
          </p>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.3}>
          <div class="mt-8">
            <GradientButton client:load openModal>
              {data.ctaText}
            </GradientButton>
          </div>
        </AnimatedSection>
      </div>
    </div>

    <!-- 3D Product Canvas -->
    <AnimatedSection client:visible delay={0.2}>
      <div class="mt-16 relative">
        <CtaProductCanvas client:load />
        <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
      </div>
    </AnimatedSection>
  </div>
</section>
