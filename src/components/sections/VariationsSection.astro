---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    products: { name: string; description: string; image: string }[];
  };
}

const { data } = Astro.props;
---

<section class="relative overflow-hidden" style="background-image: linear-gradient(180deg, rgb(255,255,255) 0%, rgb(232,232,232) 100%);">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 lg:mb-20">
      <div>
        <AnimatedSection client:visible>
          <SectionLabel text={data.label} />
        </AnimatedSection>
        <AnimatedSection client:visible delay={0.1}>
          <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[67px] leading-[0.9em] tracking-[-0.04em] gradient-text max-w-[670px]" style="background-image: linear-gradient(-45deg, rgb(13,13,13) 69%, rgb(153,153,153) 102%);">
            {data.heading}
          </h2>
        </AnimatedSection>
      </div>
      <AnimatedSection client:visible delay={0.2}>
        <p class="mt-6 lg:mt-0 text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter font-medium text-black max-w-[630px]">
          {data.description}
        </p>
      </AnimatedSection>
    </div>

    <!-- Products -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16">
      {data.products.map((product, i) => (
        <AnimatedSection client:visible delay={i * 0.15}>
          <div class="group flex flex-col items-center">
            <div class="relative w-full flex items-center justify-center">
              <img
                src={product.image}
                alt={product.name}
                class="w-full max-w-[420px] h-auto object-contain transition-transform duration-500 group-hover:scale-[1.02]"
              />
            </div>
            <div class="mt-6 w-full max-w-[420px]">
              <h3 class="font-display font-semibold text-2xl md:text-3xl lg:text-[32px] leading-[1] tracking-tighter">
                {product.name}
              </h3>
              <p class="mt-3 font-display font-medium text-base md:text-lg lg:text-[18px] leading-[1.3] tracking-tighter text-black/60">
                {product.description}
              </p>
            </div>
          </div>
        </AnimatedSection>
      ))}
    </div>

    <!-- Bottom large text -->
    <AnimatedSection client:visible delay={0.3}>
      <p class="mt-20 lg:mt-28 text-center font-display font-semibold text-2xl md:text-4xl lg:text-[48px] leading-[1.1] tracking-tighter text-black max-w-[900px] mx-auto">
        {data.description}
      </p>
    </AnimatedSection>
  </div>
</section>
