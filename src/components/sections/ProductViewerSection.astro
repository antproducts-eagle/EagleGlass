---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";
import ProductViewer360 from "../react/ProductViewer360.tsx";

interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    features: { title: string; description: string }[];
    productImage: string;
    modelSrc?: string;
  };
}

const { data } = Astro.props;
---

<section id="products" class="relative bg-white overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-32">
    <div class="flex flex-col lg:flex-row lg:items-center lg:gap-20">
      <!-- 3D Viewer -->
      <div class="flex-1 mb-12 lg:mb-0">
        <ProductViewer360 client:visible modelSrc={data.modelSrc || ""} image={data.productImage} />
      </div>

      <!-- Text content -->
      <div class="flex-1 lg:max-w-[510px]">
        <AnimatedSection client:visible>
          <SectionLabel text={data.label} />
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.1}>
          <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[67px] leading-[0.9em] tracking-[-0.04em] gradient-text" style="background-image: linear-gradient(-69deg, rgb(22,22,22) 69%, rgb(153,153,153) 102%);">
            {data.heading}
          </h2>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.2}>
          <p class="mt-8 font-display font-medium text-lg md:text-xl lg:text-[27px] leading-[1.15] tracking-tighter text-[#252525]">
            {data.description}
          </p>
        </AnimatedSection>

        <!-- Features grid -->
        <AnimatedSection client:visible delay={0.3}>
          <div class="mt-12 grid grid-cols-3 gap-6">
            {data.features.map((feature) => (
              <div class="flex flex-col gap-2">
                <h3 class="font-display font-medium text-lg tracking-tight">{feature.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{feature.description}</p>
              </div>
            ))}
          </div>
        </AnimatedSection>
      </div>
    </div>
  </div>
</section>
