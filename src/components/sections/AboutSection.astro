---
import AnimatedSection from "../react/AnimatedSection.tsx";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  data: {
    heading: string;
    description: string;
  };
}

const { data } = Astro.props;
---

<section id="about" class="relative bg-gradient-to-b from-[#e8e8e8] to-white overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 py-24 md:py-36">
    <AnimatedSection client:visible>
      <SectionLabel text="About" />
    </AnimatedSection>

    <AnimatedSection client:visible delay={0.1}>
      <h2 class="mt-3 pb-2 font-display font-semibold text-3xl md:text-5xl lg:text-[67px] leading-[0.9em] tracking-[-0.04em] gradient-text max-w-[960px]" style="background-image: linear-gradient(-54deg, rgb(0,0,0) 69%, rgb(153,153,153) 102%);">
        {data.heading}
      </h2>
    </AnimatedSection>

    <AnimatedSection client:visible delay={0.2}>
      <p class="mt-12 lg:mt-16 text-xl md:text-2xl lg:text-[35px] leading-[1.15] tracking-tighter font-medium text-[rgba(8,8,8,0.9)] max-w-[960px] lg:ml-auto">
        {data.description}
      </p>
    </AnimatedSection>
  </div>
</section>
