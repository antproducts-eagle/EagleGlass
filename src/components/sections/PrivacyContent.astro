---
import Navbar from "../react/Navbar.tsx";
import { localeLabels, getLocalePath, type Locale } from "../../i18n/config";

interface Props {
  data: {
    title: string;
    lastUpdated: string;
    sections: { heading: string; content: string }[];
  };
  navbar: {
    links: { label: string; href: string }[];
    ctaText: string;
  };
  lang: Locale;
}

const { data, navbar, lang } = Astro.props;

const localeOptions = (['en', 'nl', 'fr', 'de'] as const).map((code) => ({
  code,
  label: localeLabels[code],
  path: getLocalePath(code),
}));
---

<Navbar
  client:load
  links={navbar.links}
  ctaText={navbar.ctaText}
  currentLocale={lang}
  locales={localeOptions}
/>

<article class="pt-28 lg:pt-32 pb-24 md:pb-32">
  <div class="max-w-[780px] mx-auto px-6 md:px-10">
    <h1 class="font-display font-semibold text-4xl md:text-5xl lg:text-[56px] leading-[0.95] tracking-[-0.03em] text-black">
      {data.title}
    </h1>
    <p class="mt-4 text-sm text-black/40 font-medium">
      Last updated: {data.lastUpdated}
    </p>

    <div class="mt-12 space-y-10">
      {data.sections.map((section) => (
        <div>
          <h2 class="font-display font-semibold text-xl md:text-2xl tracking-tight text-black">
            {section.heading}
          </h2>
          <p class="mt-3 font-display font-medium text-base md:text-[17px] leading-[1.6] tracking-tight text-black/60">
            {section.content}
          </p>
        </div>
      ))}
    </div>
  </div>
</article>
